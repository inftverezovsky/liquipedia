# PostgreSQL. docker-compose.yml below uses the same defaults.
DATABASE_URL="postgresql://liquipedia:liquipedia@localhost:5432/liquipedia?schema=public"

# Liquipedia Dota 2 MediaWiki API endpoint.
LIQUIPEDIA_DOTA2_API_URL="https://liquipedia.net/dota2/api.php"

# REQUIRED for real usage: identify your project and add contact information.
# Example: "liquipedia-local-dev/0.1 (https://example.com; your-email@example.com)"
LIQUIPEDIA_USER_AGENT="liquipedia-local-dev/0.1 (contact: change-me@example.com)"

# Manual app, but still rate-limited.
LIQUIPEDIA_GENERIC_MIN_INTERVAL_MS=2100
LIQUIPEDIA_PARSE_MIN_INTERVAL_MS=31000

# Reuse recent search results for the same query.
SEARCH_CACHE_TTL_SECONDS=86400

# Optional UI base URL.
NEXT_PUBLIC_APP_NAME="liquipedia"
