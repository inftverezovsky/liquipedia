# PostgreSQL. docker-compose.yml below uses the same defaults.
DATABASE_URL="postgresql://liquipedia:liquipedia@localhost:5432/liquipedia?schema=public"

# Liquipedia Dota 2 MediaWiki API endpoint.
LIQUIPEDIA_DOTA2_API_URL="https://liquipedia.net/dota2/api.php"

# REQUIRED for real usage: identify your project and add contact information.
# Example: "liquipedia-local-dev/0.1 (https://example.com; your-email@example.com)"
LIQUIPEDIA_USER_AGENT="liquipedia-local-dev/0.1 (contact: change-me@example.com)"

# Manual app, but still rate-limited.
LIQUIPEDIA_GENERIC_MIN_INTERVAL_MS=2100
LIQUIPEDIA_PARSE_MIN_INTERVAL_MS=31000

# Reuse recent search results for the same query.
SEARCH_CACHE_TTL_SECONDS=86400

# Optional UI base URL.
NEXT_PUBLIC_APP_NAME="liquipedia"

# Admin UI/API protection.
# In production, set both values. Without ADMIN_PASSWORD, DB setting admin_password is used if present.
ADMIN_PASSWORD="63016"
ADMIN_SESSION_SECRET=
# Use true only when the app is served through HTTPS.
ADMIN_COOKIE_SECURE=false

# Optional comma-separated allowlist for sync target hosts.
EXTERNAL_PLATFORM_ALLOWED_HOSTS=

# Admin Upload mTLS (Client Certificates)
ADMIN_MTLS_ENABLED=false

# PFX/P12 mode
ADMIN_MTLS_PFX_PATH=
ADMIN_MTLS_PFX_PASSPHRASE=
ADMIN_MTLS_PFX_BASE64=

# Cert/Key mode
ADMIN_MTLS_CERT_PATH=
ADMIN_MTLS_KEY_PATH=
ADMIN_MTLS_CA_PATH=
ADMIN_MTLS_PASSPHRASE=

ADMIN_MTLS_CERT_BASE64=
ADMIN_MTLS_KEY_BASE64=
ADMIN_MTLS_CA_BASE64=

# Admin Upload Auth
# Mode: none | basic | bearer | x-api-key
ADMIN_AUTH_MODE=none

# Basic Auth
ADMIN_BASIC_USERNAME=
ADMIN_BASIC_PASSWORD=

# Bearer Token
ADMIN_API_TOKEN=

# Custom Header (x-api-key mode)
ADMIN_API_KEY_HEADER=x-api-key
ADMIN_API_KEY_VALUE=
