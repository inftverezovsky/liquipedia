{
  "name": "tcyber",
  "version": "0.1.0",
  "private": true,
  "description": "TCyber tournament admin hub: search tournaments, import matches, map teams, and send schedules to admin APIs.",
  "scripts": {
    "dev": "cross-env NODE_OPTIONS=--openssl-legacy-provider next dev -p 3010",
    "build": "prisma generate && next build",
    "start": "next start -H 0.0.0.0",
    "lint": "eslint .",
    "typecheck": "tsc --noEmit",
    "test": "tsx --test tests/**/*.test.ts",
    "test:e2e": "playwright test",
    "test:e2e:db": "cross-env RUN_DB_E2E=1 playwright test tests/e2e/fixt-send.integration.spec.ts",
    "test:all": "npm run typecheck && npm run lint && npm test && npm run test:e2e",
    "prisma:generate": "prisma generate",
    "db:push": "prisma db push",
    "db:migrate:deploy": "prisma migrate deploy",
    "db:seed": "tsx prisma/seed.ts",
    "import:dota2-admin-teams": "tsx scripts/import-admin-teams.ts",
    "setup": "npm install && npm run prisma:generate && npm run db:push && npm run db:seed"
  },
  "dependencies": {
    "@prisma/client": "^5.22.0",
    "@types/luxon": "^3.7.1",
    "@types/node-fetch": "^2.6.13",
    "axe-core": "^4.11.4",
    "cheerio": "^1.2.0",
    "clsx": "^2.1.1",
    "fast-levenshtein": "^3.0.0",
    "framer-motion": "^12.38.0",
    "https-proxy-agent": "^9.0.0",
    "lucide-react": "^1.14.0",
    "luxon": "^3.7.2",
    "minimist": "^1.2.8",
    "next": "^16.2.6",
    "node-fetch": "^2.7.0",
    "playwright": "^1.59.1",
    "playwright-extra": "^4.3.6",
    "proxy-chain": "^2.7.1",
    "puppeteer-extra-plugin-stealth": "^2.11.2",
    "react": "^19.2.6",
    "react-dom": "^19.2.6",
    "read-excel-file": "^9.0.9",
    "socks-proxy-agent": "^10.0.0",
    "swr": "^2.4.1",
    "tailwind-merge": "^3.5.0",
    "tesseract.js": "^7.0.0"
  },
  "devDependencies": {
    "@playwright/test": "^1.59.1",
    "@types/fast-levenshtein": "^0.0.4",
    "@types/node": "^20.17.6",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "autoprefixer": "^10.4.20",
    "cross-env": "^7.0.3",
    "eslint": "^9.39.4",
    "eslint-config-next": "^16.2.6",
    "postcss": "8.5.14",
    "prisma": "^5.22.0",
    "tailwindcss": "^3.4.17",
    "tsx": "^4.19.2",
    "typescript": "^5.6.3"
  },
  "prisma": {
    "seed": "tsx prisma/seed.ts"
  },
  "engines": {
    "node": "24.x"
  },
  "overrides": {
    "glob": "10.5.0",
    "postcss": "8.5.14"
  },
  "optionalDependencies": {
    "@next/swc-darwin-arm64": "16.2.6",
    "@next/swc-darwin-x64": "16.2.6",
    "@next/swc-linux-arm64-gnu": "16.2.6",
    "@next/swc-linux-arm64-musl": "16.2.6",
    "@next/swc-linux-x64-gnu": "16.2.6",
    "@next/swc-linux-x64-musl": "16.2.6",
    "@next/swc-win32-arm64-msvc": "16.2.6",
    "@next/swc-win32-x64-msvc": "16.2.6"
  }
}
