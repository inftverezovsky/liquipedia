generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum SearchStatus {
  SUCCESS
  FAILED
  CACHED
}

enum ImportStatus {
  PENDING
  SUCCESS
  PARTIAL
  FAILED
  MANUAL_REVIEW
}

model Discipline {
  id                String             @id @default(cuid())
  slug              String             @unique
  name              String
  baseApiUrl        String?
  platformId        String?
  isEnabled         Boolean            @default(true)
  createdAt         DateTime           @default(now())
  searchRequests    SearchRequest[]
  tournamentImports TournamentImport[]
}

model SearchRequest {
  id           String         @id @default(cuid())
  disciplineId String
  discipline   Discipline     @relation(fields: [disciplineId], references: [id], onDelete: Cascade)
  queryText    String
  status       SearchStatus   @default(SUCCESS)
  createdAt    DateTime       @default(now())
  results      SearchResult[]

  @@index([disciplineId, queryText, createdAt])
}

model SearchResult {
  id              String        @id @default(cuid())
  searchRequestId String
  searchRequest   SearchRequest @relation(fields: [searchRequestId], references: [id], onDelete: Cascade)
  pageId          Int
  title           String
  pageUrl         String
  snippet         String?       @db.Text
  score           Float?
  wordCount       Int?
  dates           String?
  createdAt       DateTime      @default(now())

  @@index([pageId])
  @@index([title])
}

model TournamentImport {
  id           String        @id @default(cuid())
  disciplineId String
  discipline   Discipline    @relation(fields: [disciplineId], references: [id], onDelete: Cascade)
  pageId       Int?
  pageTitle    String
  pageUrl      String
  status       ImportStatus  @default(PENDING)
  startedAt    DateTime      @default(now())
  finishedAt   DateTime?
  errorMessage String?       @db.Text
  rawSnapshots RawSnapshot[]
  tournament   Tournament?   @relation("TournamentLastImport")

  @@index([disciplineId, startedAt])
  @@index([pageTitle])
}

model RawSnapshot {
  id                 String           @id @default(cuid())
  tournamentImportId String
  tournamentImport   TournamentImport @relation(fields: [tournamentImportId], references: [id], onDelete: Cascade)
  source             String
  disciplineSlug     String?
  pageId             Int?
  pageTitle          String
  contentHash        String?
  revisionId         Int?
  revisionTimestamp  DateTime?
  rawJson            Json
  rawWikitext        String?          @db.Text
  rawHtml            String?          @db.Text
  qualityScore       Float?
  metadata           Json?
  fetchedAt          DateTime         @default(now())

  @@index([disciplineSlug, pageTitle])
  @@index([pageTitle])
  @@index([fetchedAt])
  @@index([contentHash])
}

model Tournament {
  id               String                  @id @default(cuid())
  sourcePageId     Int?
  sourceTitle      String
  sourceUrl        String
  name             String
  disciplineSlug   String
  startDate        DateTime?
  endDate          DateTime?
  location         String?
  region           String?
  organizer        String?
  prizePool        String?
  formatText       String?                 @db.Text
  status           String?
  extractionStatus ImportStatus            @default(PARTIAL)
  normalization    Json?
  platformId       String?
  lastImportId     String?                 @unique
  lastImport       TournamentImport?       @relation("TournamentLastImport", fields: [lastImportId], references: [id])
  participants     TournamentParticipant[]
  matches          TournamentMatch[]
  createdAt        DateTime                @default(now())
  updatedAt        DateTime                @updatedAt

  @@unique([disciplineSlug, sourceTitle])
  @@index([disciplineSlug])
  @@index([sourcePageId])
  @@index([name])
  @@index([sourceUrl])
}

model TournamentParticipant {
  id           String     @id @default(cuid())
  tournamentId String
  tournament   Tournament @relation(fields: [tournamentId], references: [id], onDelete: Cascade)
  name         String
  platformId   String?
  seed         String?
  region       String?
  status       String?
  logoUrl      String?
  rawText      String?    @db.Text
  createdAt    DateTime   @default(now())

  @@index([tournamentId])
  @@index([name])
}

model TournamentMatch {
  id            String     @id @default(cuid())
  matchId       String     @unique
  tournamentId  String
  tournament    Tournament @relation(fields: [tournamentId], references: [id], onDelete: Cascade)
  stage         String?
  round         String?
  matchDate     DateTime?
  matchDateTime String?
  teamAId       String?
  teamAName     String?
  teamBId       String?
  teamBName     String?
  scoreA        Int?
  scoreB        Int?
  format        String?
  status        String?
  court         String?
  sourceUrl     String?
  lpNumericalId BigInt?     @unique
  platformId    String?
  syncedAt      DateTime?
  rawText       String?    @db.Text
  hasPlaceholderTeams Boolean @default(false)
  sourceConfidence    Float?
  sourceBreakdown     Json?
  createdAt     DateTime   @default(now())

  @@index([tournamentId])
  @@index([matchDate])
  @@index([platformId])
}

model SourceFetchCache {
  id                 String    @id @default(cuid())
  source             String
  disciplineSlug     String    @default("global")
  resourceType       String
  resourceKey        String
  mode               String    @default("cache-first")
  revisionId         Int?
  revisionTimestamp  DateTime?
  contentHash        String?
  lastGoodAt         DateTime?
  lastAttemptAt      DateTime?
  lastErrorClass     String?
  qualityScore       Float?
  cacheUntil         DateTime?
  staleUntil         DateTime?
  externalRequests   Int       @default(0)
  bytesIn            Int?
  bytesOut           Int?
  cacheLayer         String?
  rawSnapshotId      String?
  metadata           Json?
  createdAt          DateTime  @default(now())
  updatedAt          DateTime  @updatedAt

  @@unique([source, disciplineSlug, resourceType, resourceKey, mode])
  @@index([source, disciplineSlug, resourceType])
  @@index([cacheUntil])
  @@index([staleUntil])
  @@index([lastGoodAt])
}

model GlobalSettings {
  key   String @id
  value String @db.Text
}

model ProxyPool {
  id            String   @id @default(cuid())
  url           String   @unique
  protocol      String   @default("http")
  host          String
  port          Int
  username      String?
  password      String?
  isActive      Boolean  @default(true)
  failCount     Int      @default(0)
  lastError     String?  @db.Text
  cooldownUntil DateTime?
  successCount  Int      @default(0)
  blockedCount  Int      @default(0)
  avgLatencyMs  Int?
  lastUsed      DateTime?
  createdAt     DateTime @default(now())
}

model ParserRequestLog {
  id             String   @id @default(cuid())
  source         String
  mode           String?
  route          String?
  disciplineSlug String?
  queryHash      String?
  proxyId        String?
  attempt        Int?
  statusCode     Int?
  errorClass     String?
  durationMs     Int?
  bytesIn        Int?
  bytesOut       Int?
  cacheLayer     String?
  cacheHit       Boolean  @default(false)
  matchesCount   Int?
  eventsCount    Int?
  createdAt      DateTime @default(now())

  @@index([source, mode, createdAt])
  @@index([disciplineSlug, createdAt])
  @@index([proxyId, createdAt])
  @@index([cacheHit, createdAt])
}

enum MappingStatus {
  unmapped
  auto_mapped
  manual_mapped
  manual_unmapped
  ambiguous
  ignored
}

model AdminTeam {
  id              String   @id @default(cuid())
  disciplineSlug  String
  platformId      String
  platformName    String
  normalizedName  String
  sourceFileName  String
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@index([disciplineSlug])
  @@index([normalizedName])
}

model TeamMapping {
  id                       String        @id @default(cuid())
  disciplineSlug           String        @default("counterstrike")
  liquipediaName           String
  liquipediaNormalizedName String?
  internalTeamId           String?
  platformId               String?
  canonicalName            String?
  confidenceScore          Float?
  matchMethod              String?
  status                   MappingStatus @default(unmapped)
  isManual                 Boolean       @default(false)
  isLockedFromAutoMapping  Boolean       @default(false)
  alias                    String?
  logoUrl                  String?
  createdAt                DateTime      @default(now())
  updatedAt                DateTime      @updatedAt

  @@unique([disciplineSlug, liquipediaName])
  @@index([liquipediaName])
  @@index([platformId])
  @@index([alias])
}

model DisciplineAdminSettings {
  id                String   @id @default(cuid())
  disciplineSlug    String   @unique
  apiUrl            String?
  adminSportId      String?
  adminMax          String?
  defaultShapkaId   String?
  timezone          String   @default("Europe/Moscow")
  dateFormat        String   @default("DD.MM.YYYY HH:mm:ss")
  requestMode       String   @default("legacy_raw") // legacy_raw, urlencoded, multipart
  sslVerify         Boolean  @default(true)
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt
}

model TournamentAdminMapping {
  id                   String   @id @default(cuid())
  disciplineSlug       String
  tournamentId         String   @unique
  sourceTournamentId   String?
  sourceTournamentName String
  adminShapkaId        String?
  adminShapkaName      String?
  createdAt            DateTime @default(now())
  updatedAt            DateTime @updatedAt

  @@index([disciplineSlug])
}

model AdminUploadLog {
  id                  String   @id @default(cuid())
  disciplineSlug      String
  tournamentId        String
  apiUrl              String
  adminSportId        String?
  adminMax            String?
  adminShapkaId       String?
  requestMode         String
  timezone            String
  dateFormat          String
  phpArrayJson        Json
  serializedFixt      String   @db.Text
  readyMatchesCount   Int
  skippedMatchesCount Int
  skippedMatchesJson  Json
  responseRaw         String?  @db.Text
  responseParsedJson  Json?
  status              String   @default("pending") // success, success_like, failed, pending
  errorMessage        String?  @db.Text
  createdAt           DateTime @default(now())

  @@index([disciplineSlug])
  @@index([tournamentId])
}
